#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -ne 1 ]; then
  echo "usage: scripts/validate-recipe <recipe-dir|recipe.yaml>" >&2
  exit 2
fi

TARGET="$1"
ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"

python3 "$ROOT_DIR/scripts/validate-recipe-yaml.py" "$TARGET"
python3 "$ROOT_DIR/scripts/validate-milestones.py" "$TARGET"

echo "validation passed: $TARGET"
